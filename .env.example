# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Facebook Graph API
FACEBOOK_PAGE_ID=your_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# Vercel Postgres (auto-populated when you add Vercel Postgres from dashboard)
POSTGRES_URL=postgres://...
POSTGRES_PRISMA_URL=postgres://...
POSTGRES_URL_NON_POOLING=postgres://...

# Vercel Cron Secret (set in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET=your_random_secret_here

# App Settings (for local CLI mode)
CRON_SCHEDULE=0 */6 * * *
MAX_POSTS_PER_DAY=4
POST_INTERVAL_HOURS=3
DB_PATH=./data/wppartner.db
VIDEO_OUTPUT_DIR=./data/videos
