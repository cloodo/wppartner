{
  "name": "wppartner",
  "version": "1.0.0",
  "description": "Broadcasting new changelogs of WordPress and WooCommerce plugins to Facebook Pages",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && mkdir -p dist/src/db && cp src/db/schema.sql dist/src/db/schema.sql",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "scrape": "tsx src/cli.ts scrape",
    "generate": "tsx src/cli.ts generate",
    "post": "tsx src/cli.ts post",
    "test": "tsx src/cli.ts test"
  },
  "keywords": [
    "woocommerce",
    "wordpress",
    "changelog",
    "facebook"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@vercel/postgres": "^0.10.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/fluent-ffmpeg": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@vercel/node": "^5.7.1",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
